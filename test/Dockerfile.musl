# Claw One musl 静态构建容器
FROM rust:1.75-alpine3.19

# 安装构建依赖
RUN apk add --no-cache \
    musl-dev \
    openssl-dev \
    openssl-libs-static \
    zlib-dev \
    zlib-static \
    git \
    nodejs \
    npm

# 添加 musl 目标（Alpine 默认使用 musl）
RUN rustup target add x86_64-unknown-linux-musl

# 设置工作目录
WORKDIR /build

# 复制项目文件
COPY hull ./hull
COPY bridge ./bridge
COPY static ./static
COPY scripts ./scripts
COPY Makefile ./
COPY config ./config

# 构建
RUN export PATH="$HOME/.cargo/bin:$PATH" && \
    make bridge && \
    cd hull && \
    cargo build --release --target x86_64-unknown-linux-musl

# 收集输出
RUN mkdir -p /output/dist && \
    cp hull/target/x86_64-unknown-linux-musl/release/claw-one /output/ && \
    cp -r static/dist /output/static && \
    echo "Build complete"
