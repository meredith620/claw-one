FROM mcr.microsoft.com/playwright:v1.59.0-node22-bookworm

WORKDIR /app

# 复制依赖文件
COPY package*.json ./
RUN npm ci

# 安装 Playwright 浏览器
RUN npx playwright install chromium --with-deps

# 复制测试代码
COPY . .

# 设置环境变量
ENV CLAW_ONE_URL=http://claw-one-test-app:8080
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

CMD ["npx", "playwright", "test", "--project=chromium"]
