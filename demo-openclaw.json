{
  "agents": {
    "defaults": {
      "model": {
        "fallbacks": [],
        "primary": "redfrog/kimi-for-coding"
      },
      "models": {
        "redfrog/kimi-for-coding": {
          "alias": "redfrog"
        },
        "test-provider/gpt-4o": {
          "alias": "gpt-4o"
        }
      },
      "workspace": "/tmp/claw-one-test-workspace"
    },
    "list": [
      {
        "id": "test-agent",
        "name": "Test Agent",
        "workspace": "/tmp/claw-one-test-workspace"
      }
    ]
  },
  "channels": {
    "mattermost": {
      "enabled": false
    }
  },
  "gateway": {
    "port": 3456
