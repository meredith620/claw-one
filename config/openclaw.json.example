{
  "gateway": {
    "host": "0.0.0.0",
    "port": 3000,
    "log_level": "info"
  },
  "models": [
    {
      "id": "default",
      "provider": "openai",
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "https://api.openai.com/v1",
      "model": "gpt-4"
    }
  ],
  "channels": {
    "telegram": {
      "enabled": false,
      "bot_token": "${TELEGRAM_BOT_TOKEN}"
    }
  },
  "claw_one": {
    "config_path": "~/.config/claw-one",
    "auto_backup": true,
    "safe_mode": true
  }
}
